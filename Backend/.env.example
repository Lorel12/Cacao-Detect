# Configuration environment file
# Copy this to .env and modify with your settings

# Application
APP_NAME=CacaoDetect
APP_VERSION=1.0.0
DEBUG=True

# Database PostgreSQL
DATABASE_URL=postgresql://cacaouser:cacaopass@localhost:5432/cacaodetect

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# File Upload
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=["jpg","jpeg","png"]

# S3 (Optional)
USE_S3=False
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# IA Model
IA_MODEL_PATH=./models/cacao_disease_detection.h5
IA_CONFIDENCE_THRESHOLD=0.6
IA_TIMEOUT_SECONDS=30
